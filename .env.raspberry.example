SIGNALMAKER_BASE_URL=https://mysginalmaker.replit.app
GATEWAY_ID=raspberry-fr-1
POLL_SECONDS=45
DRY_RUN=false
QUOTE_ASSETS=USD,USDC
ORDER_QUOTE_AMOUNT=20
MAX_CANDIDATE_AGE_SECONDS=900
APP_PORT=8080
EXECUTOR_API_PORT=8080
EXECUTOR_DASHBOARD_PORT=8080
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/signalmaker

EXECUTION_EXCHANGE=kraken
KRAKEN_BASE_URL=https://api.kraken.com
KRAKEN_API_KEY=
KRAKEN_SECRET_KEY=
EXECUTION_MODE=cross
MARGIN_MODE_ENABLED=true
MARGIN_ACCOUNT_MODE=cross
MARGIN_ISOLATED=false

CANDLE_FEED_ENABLED=true
CANDLE_FEED_INTERVALS=15m,1h,4h
CANDLE_FEED_LIMIT=50
CANDLE_FEED_POLL_SECONDS=600
CANDLE_FEED_MAX_SYMBOLS=150
CANDLE_FEED_MAX_WORKERS=1
CANDLE_FEED_KRAKEN_REQUESTS_PER_MINUTE=120
CANDLE_FEED_SMOKE_SYMBOL_LIMIT=3

MOMENTUM_CANDIDATES_SYNC_ENABLED=false
MOMENTUM_CANDIDATES_LIMIT=100
MOMENTUM_CANDIDATES_MIN_SCORE=0
MOMENTUM_CANDIDATES_MIN_RR=
MOMENTUM_CANDIDATES_REQUIRE_WYCKOFF_CONTEXT=true
MOMENTUM_CANDIDATES_HTTP_TIMEOUT_SEC=20

MOMENTUM_DECISION_ENABLED=true
MOMENTUM_DECISION_EXECUTE_ENABLED=true
MOMENTUM_DECISION_POLL_SECONDS=300
MOMENTUM_DECISION_PATH=/api/v1/momentum
MOMENTUM_DECISION_METHOD=GET
MOMENTUM_DECISION_LIMIT=25
MOMENTUM_CANDIDATES_PATH=/api/v1/momentum
MOMENTUM_DECISION_CANDIDATES_FALLBACK_ENABLED=true
MOMENTUM_DECISION_FALLBACK_LIMIT=25
MOMENTUM_DECISION_MIN_SCORE=0
MOMENTUM_BUYABLE_RSI_1H_MIN=45
MOMENTUM_BUYABLE_RSI_1H_MAX=55

WEB_HOST=0.0.0.0
ADMIN_PASSWORD=

IBKR_MARKET_FEED_ENABLED=false
IBKR_CP_BASE_URL=https://localhost:5000/v1/api
IBKR_CP_VERIFY_SSL=false
IBKR_CP_TIMEOUT_SECONDS=30
IBKR_MARKET_FEED_POLL_SECONDS=3600
IBKR_MARKET_FEED_INTERVALS=1d
IBKR_MARKET_FEED_PERIOD=2y
IBKR_MARKET_FEED_BAR=1d
IBKR_MARKET_FEED_SOURCE=Last
IBKR_MARKET_FEED_OUTSIDE_RTH=false
IBKR_MARKET_FEED_MAX_WORKERS=1
IBKR_MARKET_FEED_REQUESTS_PER_MINUTE=20
IBKR_MARKET_FEED_LIMIT=300
IBKR_MARKET_FEED_QUEUE_ANALYSIS=false
IBKR_MARKET_FEED_UNIVERSE=ETF PEA,ETF Europe UCITS,Stocks Euronext Paris,Stocks Europe
IBKR_MARKET_FEED_ASSET_TYPES=ETF,STOCK
IBKR_MARKET_FEED_SYMBOLS=
IBKR_CONTRACT_CACHE_PATH=raspberry_executor/ibkr_contract_cache.json
IBKR_MARKET_FEED_RETRY_QUEUE_PATH=raspberry_executor/ibkr_market_retry_queue.json
SIGNALMAKER_STOCK_ETF_IBKR_INGEST_PATH=/api/v1/stocks-etfs/ibkr/candles
SIGNALMAKER_STOCK_ETF_ASSETS_PATH=/api/v1/stocks-etfs/assets
