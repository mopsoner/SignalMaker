SIGNALMAKER_BASE_URL=https://your-signalmaker-app.replit.app
GATEWAY_ID=raspberry-fr-1
POLL_SECONDS=15
DRY_RUN=true

# ETHUSDT becomes ETHUSDC when EXECUTION_QUOTE_ASSET=USDC.
# Change to FDUSD, USDT, etc. if needed.
EXECUTION_QUOTE_ASSET=USDC

# Optional. Leave empty to allow every candidate symbol.
ALLOWED_SYMBOLS=

ORDER_QUANTITY=0.001
MAX_CANDIDATE_AGE_SECONDS=900

BINANCE_BASE_URL=https://api.binance.com
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
