# Historical SignalMaker variables kept for reference only.
# Do not copy these into a current Raspberry executor .env unless you are
# intentionally running an old/legacy deployment that still supports them.

# Legacy margin execution settings removed from the current Raspberry example.
EXECUTION_MODE=cross
MARGIN_MODE_ENABLED=true
MARGIN_ACCOUNT_MODE=cross
MARGIN_ISOLATED=false

# Legacy IBKR stock/ETF market-feed settings removed from the current Raspberry example.
IBKR_MARKET_FEED_ENABLED=false
IBKR_CP_BASE_URL=https://localhost:5000/v1/api
IBKR_CP_VERIFY_SSL=false
IBKR_CP_TIMEOUT_SECONDS=30
IBKR_MARKET_FEED_POLL_SECONDS=3600
IBKR_MARKET_FEED_INTERVALS=1d
IBKR_MARKET_FEED_PERIOD=2y
IBKR_MARKET_FEED_BAR=1d
IBKR_MARKET_FEED_SOURCE=Last
IBKR_MARKET_FEED_OUTSIDE_RTH=false
IBKR_MARKET_FEED_MAX_WORKERS=1
IBKR_MARKET_FEED_REQUESTS_PER_MINUTE=20
IBKR_MARKET_FEED_LIMIT=300
IBKR_MARKET_FEED_QUEUE_ANALYSIS=false
IBKR_MARKET_FEED_UNIVERSE=ETF PEA,ETF Europe UCITS,Stocks Euronext Paris,Stocks Europe
IBKR_MARKET_FEED_ASSET_TYPES=ETF,STOCK
IBKR_MARKET_FEED_SYMBOLS=
IBKR_CONTRACT_CACHE_PATH=raspberry_executor/ibkr_contract_cache.json
IBKR_MARKET_FEED_RETRY_QUEUE_PATH=raspberry_executor/ibkr_market_retry_queue.json
SIGNALMAKER_STOCK_ETF_IBKR_INGEST_PATH=/api/v1/stocks-etfs/ibkr/candles
SIGNALMAKER_STOCK_ETF_ASSETS_PATH=/api/v1/stocks-etfs/assets
