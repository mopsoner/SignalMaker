APP_NAME=SignalMaker
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/signalmaker
SQL_ECHO=false
CREATE_TABLES_ON_BOOT=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
BINANCE_REST_BASE=https://api.binance.com
BINANCE_TESTNET_REST_BASE=https://testnet.binance.vision
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_QUOTE_ASSETS=USDT,USDC
BINANCE_SYMBOL_STATUS=TRADING
BINANCE_MAX_SYMBOLS=25
BINANCE_COLLECT_MAX_WORKERS=4
BINANCE_INCREMENTAL_FETCH_ENABLED=true
BINANCE_INCREMENTAL_MIN_1M=3
BINANCE_INCREMENTAL_MIN_5M=3
BINANCE_INCREMENTAL_MIN_15M=3
BINANCE_INCREMENTAL_MIN_1H=2
BINANCE_INCREMENTAL_MIN_4H=2
BINANCE_LOOKBACK_1M=180
BINANCE_LOOKBACK_5M=180
BINANCE_LOOKBACK_15M=180
BINANCE_LOOKBACK_1H=180
BINANCE_LOOKBACK_4H=120
LIVE_TRADING_ENABLED=false
BINANCE_USE_TESTNET=true
LIVE_SPOT_ALLOW_SHORTS=false
LIVE_MAX_OPEN_POSITIONS=3
LIVE_MAX_NOTIONAL_PER_TRADE=250
LIVE_REQUIRE_TP_SL=true
LIVE_RECONCILE_ENABLED=true
SESSION_TIMEZONE_OFFSET_HOURS=-4
SIGNAL_EXECUTION_INTERVAL=15m
SIGNAL_RSI_PERIOD=14
SIGNAL_SWING_WINDOW=8
SIGNAL_EQUAL_LEVEL_TOLERANCE_PCT=0.0015
SIGNAL_OVERBOUGHT=70
SIGNAL_OVERSOLD=30
SIGNAL_ENTRY_RSI_MIN=45
SIGNAL_ENTRY_RSI_MAX=55
SIGNAL_ENTRY_RSI_TIMEFRAME=1h
SIGNAL_PRICE_NEAR_EXTREME_PCT=0.0025
SIGNAL_SESSION_CONFIRM_FILTER_ENABLED=true
PLANNER_MIN_SCORE=4
PLANNER_MIN_RR=0.8

# Optional IBKR market-data provider (Interactive Brokers Web API / IB REST API)
# For individual/retail accounts, IBKR documents Client Portal Gateway auth.
# OAuth2 private_key_jwt direct access is intended for approved institutional/beta integrations.
IBKR_ENABLED=false
IBKR_AUTH_METHOD=gateway # gateway, bearer, or oauth2_private_key_jwt
IBKR_BEARER_TOKEN=
IBKR_BASE_URL=https://api.ibkr.com
IBKR_TRADING_BASE_PATH=/v1/api
IBKR_DEFAULT_EXCHANGE=SMART
IBKR_DEFAULT_TIMEFRAME=1d
IBKR_REQUEST_SLEEP_SECONDS=1
IBKR_MAX_CONCURRENT=2
IBKR_START_DATE=2020-01-01
IBKR_HISTORY_PERIOD=5y
IBKR_HISTORY_BAR=1d
IBKR_USE_RTH=true
IBKR_OAUTH2_TOKEN_URL=https://api.ibkr.com/oauth2/api/v1/token
IBKR_OAUTH2_CLIENT_ID=
IBKR_OAUTH2_PRIVATE_KEY=
IBKR_OAUTH2_PRIVATE_KEY_FILE=
IBKR_OAUTH2_KEY_ID=
IBKR_OAUTH2_SCOPE=
IBKR_OAUTH2_GRANT_TYPE=client_credentials
IBKR_OAUTH2_JWT_ALGORITHM=RS256
IBKR_OAUTH2_ASSERTION_TTL_SECONDS=300
# MARKET_DATA_PRIMARY_PROVIDER=IBKR
