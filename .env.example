APP_NAME=SignalMaker
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=5000
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/signalmaker
SQL_ECHO=false
CREATE_TABLES_ON_BOOT=true
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000,http://127.0.0.1:5000
CORS_ORIGIN_REGEX=http://192\\.168\\.[0-9]{1,3}\\.[0-9]{1,3}:3000|http://10\\.[0-9]{1,3}\\.[0-9]{1,3}\\.[0-9]{1,3}:3000|http://172\\.(1[6-9]|2[0-9]|3[0-1])\\.[0-9]{1,3}\\.[0-9]{1,3}:3000
EXECUTION_EXCHANGE=kraken
QUOTE_ASSETS=USDC
KRAKEN_REST_BASE=https://api.kraken.com
KRAKEN_TESTNET_REST_BASE=https://testnet.kraken.vision
KRAKEN_API_KEY=
KRAKEN_SECRET_KEY=
KRAKEN_BASE_URL=https://api.kraken.com
KRAKEN_API_KEY=
KRAKEN_SECRET_KEY=
KRAKEN_QUOTE_ASSETS=USDT,USDC
KRAKEN_SYMBOL_STATUS=TRADING
KRAKEN_MAX_SYMBOLS=25
KRAKEN_COLLECT_MAX_WORKERS=4
KRAKEN_INCREMENTAL_FETCH_ENABLED=true
KRAKEN_INCREMENTAL_MIN_1M=3
KRAKEN_INCREMENTAL_MIN_5M=3
KRAKEN_INCREMENTAL_MIN_1H=2
KRAKEN_INCREMENTAL_MIN_4H=2
KRAKEN_LOOKBACK_1M=180
KRAKEN_LOOKBACK_5M=180
KRAKEN_LOOKBACK_1H=180
KRAKEN_LOOKBACK_4H=120
LIVE_TRADING_ENABLED=false
KRAKEN_USE_TESTNET=true
LIVE_SPOT_ALLOW_SHORTS=false
LIVE_MAX_OPEN_POSITIONS=3
LIVE_MAX_NOTIONAL_PER_TRADE=250
LIVE_REQUIRE_TP_SL=true
LIVE_RECONCILE_ENABLED=true

SIGNALMAKER_BASE_URL=https://mysginalmaker.replit.app
MOMENTUM_CANDIDATES_SYNC_ENABLED=false
MOMENTUM_CANDIDATES_LIMIT=100
MOMENTUM_CANDIDATES_MIN_SCORE=0
MOMENTUM_CANDIDATES_MIN_RR=
MOMENTUM_CANDIDATES_REQUIRE_WYCKOFF_CONTEXT=true
MOMENTUM_CANDIDATES_HTTP_TIMEOUT_SEC=20
SESSION_TIMEZONE_OFFSET_HOURS=-4
SIGNAL_RSI_PERIOD=14
SIGNAL_SWING_WINDOW=8
SIGNAL_EQUAL_LEVEL_TOLERANCE_PCT=0.0015
SIGNAL_OVERBOUGHT=70
SIGNAL_OVERSOLD=30
SIGNAL_PRICE_NEAR_EXTREME_PCT=0.0025
SIGNAL_SESSION_CONFIRM_FILTER_ENABLED=true
PLANNER_MIN_SCORE=4
PLANNER_MIN_RR=0.8
